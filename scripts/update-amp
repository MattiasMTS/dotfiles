#!/usr/bin/env bash
set -euo pipefail

OVERLAY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../overlays" && pwd)"
OVERLAY_FILE="$OVERLAY_DIR/amp-cli.nix"

# Get latest version from the npm registry
echo "Checking latest @sourcegraph/amp version..."
LATEST_VERSION=$(curl -fsSL "https://registry.npmjs.org/@sourcegraph%2Famp" | jq -r '."dist-tags".latest')
CURRENT_VERSION=$(grep 'version = ' "$OVERLAY_FILE" | head -1 | sed 's/.*"\(.*\)".*/\1/')

if [ "$LATEST_VERSION" = "$CURRENT_VERSION" ]; then
  echo "Already up to date: $CURRENT_VERSION"
  exit 0
fi

echo "Updating amp-cli: $CURRENT_VERSION -> $LATEST_VERSION"

# Get new source hash
echo "Fetching source hash..."
SRC_HASH=$(nix-prefetch-url "https://registry.npmjs.org/@sourcegraph/amp/-/amp-${LATEST_VERSION}.tgz" 2>/dev/null)
SRC_HASH_SRI=$(nix hash convert --hash-algo sha256 --to sri "$SRC_HASH")

# Update version, tarball hash, and reset nodeModulesHash
DUMMY_HASH="sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
sed -i '' "s|$CURRENT_VERSION|$LATEST_VERSION|g" "$OVERLAY_FILE"
sed -i '' "s|tarballHash = \"sha256-.*\";|tarballHash = \"${SRC_HASH_SRI}\";|" "$OVERLAY_FILE"
sed -i '' "s|nodeModulesHash = \"sha256-.*\";|nodeModulesHash = \"${DUMMY_HASH}\";|" "$OVERLAY_FILE"

# Build to extract the correct fixed-output hash from the mismatch
echo "Computing nodeModulesHash..."
NODE_MODULES_HASH=$(nix build .#darwinConfigurations.Mattiass-MacBook-Pro.pkgs.amp-cli --no-link 2>&1 \
  | grep "got:" | head -1 | awk '{print $2}') || true

if [ -n "$NODE_MODULES_HASH" ]; then
  sed -i '' "s|nodeModulesHash = \"${DUMMY_HASH}\";|nodeModulesHash = \"${NODE_MODULES_HASH}\";|" "$OVERLAY_FILE"
  echo "Updated amp-cli to $LATEST_VERSION"
  echo "Run 'darwin-rebuild switch --flake ~/src/github.com/projects/dotfiles' to apply."
else
  echo "Could not auto-detect nodeModulesHash. Update nodeModulesHash in $OVERLAY_FILE manually."
fi
